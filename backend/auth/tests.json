{
  "tests": [
    {
      "name": "Register new user",
      "method": "POST",
      "path": "/?action=register",
      "body": {"username": "testuser99", "login": "test99@bracelet.ru", "password": "test123"},
      "expectedStatus": 200,
      "expectedBody": {"session_id": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login with email",
      "method": "POST",
      "path": "/?action=login",
      "body": {"login": "test99@bracelet.ru", "password": "test123"},
      "expectedStatus": 200,
      "expectedBody": {"session_id": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Wrong password",
      "method": "POST",
      "path": "/?action=login",
      "body": {"login": "test99@bracelet.ru", "password": "wrongpass"},
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    }
  ]
